# MTRX Environment Configuration
# Copy to .env and fill in values

# Deployer private key (never commit the real .env file)
PRIVATE_KEY=0x_your_private_key_here

# Basescan API key for contract verification
BASESCAN_API_KEY=your_basescan_api_key

# NeoSafe address (immutable — do not change)
NEOSAFE_ADDRESS=0x46fF491D7054A6F500026B3E81f358190f8d8Ec5

# Oracle interface address (set after Component 11 deployment)
ORACLE_ADDRESS=

# Dardan Telegram ID (for emergency bypass notifications)
DARDAN_TELEGRAM_ID=your_telegram_id_here
