# =============================================================================
# Component 11 - Oracle Service Credentials
# =============================================================================
# Copy this file to .env and fill in your API keys.
# NEVER commit the actual .env file to version control.
# =============================================================================

# -- Chainlink (on-chain, no API key needed for read) --
# CHAINLINK_RPC_URL=https://mainnet.base.org

# -- Weather Data Providers --
# OPENWEATHERMAP_API_KEY=
# WEATHERAPI_KEY=
# TOMORROW_IO_API_KEY=

# -- Sports Data Providers --
# ESPN_API_KEY=
# THESCORE_API_KEY=
# SPORTRADAR_API_KEY=

# -- Flight Data Providers --
# FLIGHTAWARE_API_KEY=
# AVIATIONSTACK_API_KEY=
# FLIGHTSTATS_APP_ID=
# FLIGHTSTATS_APP_KEY=

# -- Delivery / Shipping Providers --
# USPS_USER_ID=
# UPS_ACCESS_KEY=
# UPS_USER_ID=
# UPS_PASSWORD=
# FEDEX_API_KEY=
# FEDEX_SECRET_KEY=
# DHL_API_KEY=

# -- Base RPC --
# BASE_RPC_URL=https://mainnet.base.org
# BASE_WS_URL=wss://mainnet.base.org

# -- Platform --
# PLATFORM_PRIVATE_KEY=
# NEOSAFE_ADDRESS=0x46fF491D7054A6F500026B3E81f358190f8d8Ec5
